        P5 --> ES
        P6 --> ES
        P7 --> ES
        P8 --> CS[Certificate Store - W3C VC 2.0]
        P9 --> DD[Drift Detection - Evidently AI]

        BE --> ES
        PG --> ES
        CS --> ES
        DD --> ES
    end

    subgraph Outputs & Feedback
