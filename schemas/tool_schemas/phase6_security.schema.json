{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ethosmcp.ai/schemas/tool_schemas/phase6_security.schema.json",
  "title": "Phase 6 – Security Assessment Schema",
  "description": "Validates the payload for security and robustness evaluation of an AI model.",
  "type": "object",
  "required": [
    "run_id",
    "model_endpoint",
    "test_suites",
    "threat_model",
    "model_type"
  ],
  "additionalProperties": false,
  "properties": {
    "run_id": {
      "type": "string",
      "format": "uuid",
      "description": "Audit run UUID"
    },
    "model_endpoint": {
      "type": "string",
      "format": "uri",
      "description": "URI of the model endpoint being evaluated for security"
    },
    "test_suites": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["adversarial_evasion", "data_poisoning", "model_inversion", "membership_inference", "model_stealing", "prompt_injection", "jailbreak", "output_manipulation"]
      },
      "minItems": 1,
      "description": "Security test suites to execute"
    },
    "threat_model": {
      "type": "object",
      "description": "Threat model description for the AI system",
      "properties": {
        "attack_surface": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Identified attack surfaces"
        },
        "adversary_capabilities": {
          "type": "string",
          "enum": ["black_box", "gray_box", "white_box"],
          "description": "Assumed adversary capabilities"
        },
        "risk_tolerance": {
          "type": "string",
          "enum": ["low", "medium", "high"],
          "description": "Organizational risk tolerance for security findings"
        }
      },
      "additionalProperties": false
    },
    "model_type": {
      "type": "string",
      "enum": ["llm", "classification", "regression", "generative", "embedding", "ensemble", "other"],
      "description": "Type of AI model being assessed"
    }
  }
}
