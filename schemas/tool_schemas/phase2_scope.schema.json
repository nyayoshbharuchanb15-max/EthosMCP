{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ethosmcp.ai/schemas/tool_schemas/phase2_scope.schema.json",
  "title": "Phase 2 – Audit Scope Definition Schema",
  "description": "Validates the payload for defining the regulatory scope of an audit run.",
  "type": "object",
  "required": [
    "run_id",
    "jurisdictions",
    "system_type",
    "deployment_context"
  ],
  "additionalProperties": false,
  "properties": {
    "run_id": {
      "type": "string",
      "format": "uuid",
      "description": "Audit run UUID returned from phase 1 registration"
    },
    "jurisdictions": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["EU", "US", "IN", "UK", "BR", "JP", "KR", "SG", "AU", "CA", "CH", "NG"]
      },
      "minItems": 1,
      "description": "Jurisdictions to scope regulatory frameworks against"
    },
    "system_type": {
      "type": "string",
      "enum": ["chatbot", "recommendation", "classification", "generation", "decision", "biometric", "prediction"],
      "description": "Category of the AI system being audited"
    },
    "deployment_context": {
      "type": "string",
      "enum": ["B2B", "B2C", "internal", "public_sector", "critical_infrastructure"],
      "description": "Deployment context affecting regulatory obligations"
    }
  }
}
