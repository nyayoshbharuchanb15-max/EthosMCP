{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ethosmcp.ai/schemas/tool_schemas/phase7_explain.schema.json",
  "title": "Phase 7 – Explainability Assessment Schema",
  "description": "Validates the payload for explainability and interpretability evaluation.",
  "type": "object",
  "required": [
    "run_id",
    "model_endpoint",
    "explainability_method",
    "sample_count",
    "feature_names"
  ],
  "additionalProperties": false,
  "properties": {
    "run_id": {
      "type": "string",
      "format": "uuid",
      "description": "Audit run UUID"
    },
    "model_endpoint": {
      "type": "string",
      "format": "uri",
      "description": "URI of the model endpoint to generate explanations for"
    },
    "explainability_method": {
      "type": "string",
      "enum": ["shap", "lime", "integrated_gradients", "attention", "counterfactual", "anchors"],
      "description": "Explainability technique to apply"
    },
    "sample_count": {
      "type": "integer",
      "minimum": 1,
      "maximum": 10000,
      "description": "Number of samples to use for explanation generation"
    },
    "feature_names": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1,
      "description": "Names of features to explain"
    }
  }
}
