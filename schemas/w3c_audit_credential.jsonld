{
  "@context": [
    "https://www.w3.org/ns/credentials/v2",
    "https://w3id.org/security/suites/ed25519-2020/v1"
  ],
  "type": ["VerifiableCredential", "AIAuditCertificate"],
  "issuer": "did:key:{{DID_GENERATED_BY_KEYGEN_PY}}",
  "issuanceDate": "{{ISO8601_UTC_TIMESTAMP}}",
  "credentialSubject": {
    "id": "did:audit:{{RUN_ID}}",
    "auditRunId": "{{RUN_ID}}",
    "complianceStatus": "Compliant",
    "merkle_root": "{{SHA256_OF_ALL_PHASE_ARTIFACTS}}",
    "rfc3161_timestamp": {
      "token_base64": "{{RFC3161_TOKEN}}",
      "tsa_url": "{{TSA_URL}}"
    }
  },
  "proof": {
    "type": "Ed25519Signature2020",
    "created": "{{ISO8601_UTC_TIMESTAMP}}",
    "verificationMethod": "did:key:{{DID_GENERATED_BY_KEYGEN_PY}}#{{DID_GENERATED_BY_KEYGEN_PY}}",
    "proofPurpose": "assertionMethod",
    "proofValue": "{{SIGNED_BY_SIGNER_PY}}"
  },
  "statusListCredential": "http://localhost:8080/status-lists/revocations-2026.json"
}
