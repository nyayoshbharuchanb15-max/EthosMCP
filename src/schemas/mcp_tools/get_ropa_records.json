{
  "name": "get_ropa_records",
  "description": "Retrieves Records of Processing Activities (ROPA) metadata for compliance audit. Returns governance baseline metrics, legal basis coverage, and processing pipeline mappings. Never returns raw personal data.",
  "inputSchema": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "properties": {
      "organization_id": {"type": "string", "pattern": "^[a-zA-Z0-9_-]{3,64}$", "description": "Unique identifier for the organization or subsidiary being audited", "examples": ["acme_hq"]},
      "scope": {"type": "string", "enum": ["full", "high_risk_only", "ai_systems_only", "third_party_processors"], "description": "Scope of ROPA records to retrieve", "default": "full", "examples": ["full"]},
      "jurisdiction": {"type": "array", "items": {"type": "string", "enum": ["GDPR", "DPDP", "EU_AI_ACT", "ALL"]}, "description": "Regulatory frameworks to validate against", "default": ["ALL"], "examples": [["GDPR", "EU_AI_ACT"]]},
      "include_sub_entities": {"type": "boolean", "description": "Whether to include subsidiary and joint-controller entities", "default": false, "examples": [false]},
      "state_token_input": {"type": ["string", "null"], "description": "Not required for Phase 1. Must be null or omitted.", "examples": [null]}
    },
    "required": ["organization_id"],
    "additionalProperties": false
  },
  "outputSchema": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "properties": {
      "governance_baseline_v1": {"type": "string", "description": "State token for Phase 2 input"},
      "ropa_coverage_percent": {"type": "number"},
      "unmapped_pipelines": {"type": "integer"},
      "legal_basis_breakdown": {"type": "object"},
      "high_risk_processing_count": {"type": "integer"},
      "errors": {"type": "array", "items": {"$ref": "#/definitions/ComplianceError"}},
      "audit_trail": {"$ref": "#/definitions/AuditTrailMarker"}
    },
    "required": ["governance_baseline_v1", "ropa_coverage_percent", "unmapped_pipelines"],
    "definitions": {
      "ComplianceError": {"type": "object"},
      "AuditTrailMarker": {"type": "object"}
    }
  }
}
