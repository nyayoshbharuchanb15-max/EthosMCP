{
  "name": "analyze_data_flow",
  "description": "Analyzes data flow metadata for compliance audit. Returns topology, transfer direction, and jurisdictional mapping only.",
  "inputSchema": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "properties": {
      "organization_id": {"type": "string", "pattern": "^[a-zA-Z0-9_-]{3,64}$", "description": "Unique identifier for the organization or subsidiary being audited", "examples": ["acme_hq"]},
      "scope": {"type": "string", "enum": ["full", "external_transfers", "internal_only"], "description": "Scope of data-flow records to retrieve", "default": "full", "examples": ["external_transfers"]},
      "jurisdiction": {"type": "array", "items": {"type": "string", "enum": ["GDPR", "DPDP", "EU_AI_ACT", "ALL"]}, "description": "Regulatory frameworks to validate against", "default": ["ALL"], "examples": [["GDPR"]]}
    },
    "required": ["organization_id"],
    "additionalProperties": false
  },
  "outputSchema": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "properties": {
      "localization_baseline_v1": {"type": "string", "description": "State token for Phase 3 input"},
      "cross_border_transfers": {"type": "integer"},
      "unapproved_regions": {"type": "array", "items": {"type": "string"}},
      "errors": {"type": "array", "items": {"$ref": "#/definitions/ComplianceError"}},
      "audit_trail": {"$ref": "#/definitions/AuditTrailMarker"}
    },
    "required": ["localization_baseline_v1", "cross_border_transfers"],
    "definitions": {
      "ComplianceError": {"type": "object"},
      "AuditTrailMarker": {"type": "object"}
    }
  }
}
