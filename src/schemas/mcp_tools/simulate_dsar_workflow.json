{
  "name": "simulate_dsar_workflow",
  "description": "Simulates DSAR propagation across system layers without executing deletions.",
  "inputSchema": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "properties": {
      "organization_id": {"type": "string", "pattern": "^[a-zA-Z0-9_-]{3,64}$", "description": "Unique identifier for the organization or subsidiary being audited", "examples": ["acme_hq"]},
      "subject_identifier_hash": {"type": "string", "description": "Hash of the data principal identifier"},
      "request_type": {"type": "string", "enum": ["access", "erasure", "rectification", "portability", "restriction"], "examples": ["erasure"]},
      "jurisdiction": {"type": "string", "enum": ["GDPR", "DPDP"], "examples": ["GDPR"]},
      "simulation_mode": {"type": "boolean", "default": true, "examples": [true]}
    },
    "required": ["organization_id", "subject_identifier_hash", "request_type"],
    "additionalProperties": false
  },
  "outputSchema": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "properties": {
      "security_posture_v1": {"type": "string", "description": "State token for Phase 4 input"},
      "propagation_status": {"type": "object"},
      "sla_deadline_days": {"type": "integer"},
      "verification_notes": {"type": "array", "items": {"type": "string"}},
      "errors": {"type": "array", "items": {"$ref": "#/definitions/ComplianceError"}}
    },
    "required": ["security_posture_v1", "propagation_status", "sla_deadline_days"],
    "definitions": {
      "ComplianceError": {"type": "object"},
      "AuditTrailMarker": {"type": "object"}
    }
  }
}
