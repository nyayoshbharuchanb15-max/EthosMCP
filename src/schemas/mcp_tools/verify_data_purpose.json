{
  "name": "verify_data_purpose",
  "description": "Check if an AI request aligns with the allowed data usage purpose under EU AI Act and GDPR purpose-limitation principles. Returns a compliance verdict for the requested dataset-purpose combination.",
  "inputSchema": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "properties": {
      "dataset_id": {
        "type": "string",
        "description": "Identifier of the dataset to check against the purpose registry",
        "pattern": "^[a-zA-Z0-9_-]{3,64}$",
        "examples": ["DS-CUSTOMER-001"]
      },
      "requested_purpose": {
        "type": "string",
        "description": "The purpose for which the dataset will be used (e.g. 'billing', 'model_training')",
        "examples": ["billing", "model_training", "third_party_marketing"]
      }
    },
    "required": ["dataset_id", "requested_purpose"],
    "additionalProperties": false
  },
  "outputSchema": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "properties": {
      "audit_id": {"type": "string"},
      "framework": {"type": "string"},
      "overall_status": {"type": "string", "enum": ["COMPLIANT", "NON_COMPLIANT"]},
      "results": {"type": "array"},
      "execution_timestamp": {"type": "string"},
      "query_hash_digest": {"type": "string"},
      "response_signature": {"type": "string"},
      "data_state_hash": {"type": "string"}
    },
    "required": ["audit_id", "overall_status"]
  }
}
