# =============================================================================
# AI Compliance MCP Server – Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
#   cp .env.example .env
# NEVER commit .env to version control.
# =============================================================================

# --- MCP Server ---
MCP_TRANSPORT=http
MCP_PORT=3000
ORCHESTRATOR_URL=http://orchestrator:8080

# --- OAuth 2.1 (Keycloak) ---
OAUTH_JWKS_URI=http://keycloak:8080/realms/ai-compliance/protocol/openid-connect/certs
OAUTH_ISSUER=http://keycloak:8080/realms/ai-compliance
OAUTH_AUDIENCE=ai-compliance-mcp

# --- Orchestrator ---
DATABASE_URL=postgresql+asyncpg://governance_admin:secure_password_change_me@postgres:5432/ai_compliance
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=secure_password_change_me
REDIS_URL=redis://redis:6379

# --- NATS JetStream ---
NATS_URL=nats://nats:4222

# --- KMS ---
# KMS_TYPE=vault      # HashiCorp Vault (production)
# KMS_TYPE=local      # Local Ed25519 key file (dev)
KMS_TYPE=vault
VAULT_ADDR=http://vault:8200
VAULT_TOKEN=devroot

# --- RFC 3161 Timestamp Authority ---
TSA_URL=http://timestamp.digicert.com

# --- Status List (on-premise) ---
STATUS_LIST_BASE_URL=http://status-list-server:80/status-lists

# --- Logging ---
LOG_LEVEL=INFO
LOG_FORMAT=json

# --- Regulatory Feeds ---
ENABLE_LIVE_REGULATORY_FEEDS=false
